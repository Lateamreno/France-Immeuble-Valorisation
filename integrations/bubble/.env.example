# Lecture Bubble Data API (France Immeuble → Valorisation)
# Copier en .env (déjà gitignoré) et remplir. NE JAMAIS committer .env.

# URL racine de l'app Bubble France Immeuble (sans slash final)
#   - domaine Bubble : https://ton-app.bubbleapps.io
#   - ou domaine custom : https://app.france-immeuble.fr
BUBBLE_APP_URL=

# Token API privé Bubble (Settings → API → API Tokens).
# Facultatif si les data types sont exposés en lecture publique.
BUBBLE_API_TOKEN=

# Environnement : "live" (défaut) ou "test" (utilise /version-test)
BUBBLE_ENV=live
